{
  "name": "shipmail-mcp",
  "version": "0.1.6",
  "description": "Official Model Context Protocol (MCP) server for Shipmail, a business email provider with REST API, webhooks, and custom-domain inboxes for AI agents.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "shipmail-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "keywords": [
    "shipmail",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "email",
    "email-api",
    "email-hosting",
    "business-email",
    "custom-domain-email",
    "inbound-email",
    "agent-inbox",
    "rest-api",
    "webhooks",
    "ai-agent",
    "claude",
    "cursor"
  ],
  "author": "ShipMail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcoulaud/shipmail-mcp.git"
  },
  "homepage": "https://shipmail.to/docs/mcp",
  "bugs": {
    "url": "https://github.com/jcoulaud/shipmail-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "shipmail": "0.1.23",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
